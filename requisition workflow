@app.route('/request/<int:asset_id>')
def request_asset(asset_id):
    req = Requisition(
        user_id=session['user_id'],
        asset_id=asset_id
    )
    db.session.add(req)
    db.session.commit()
    return "Request Sent"
@app.route('/approve/<int:req_id>')
@admin_required
def approve(req_id):
    req = Requisition.query.get(req_id)
    req.status = 'approved'
    
    allocation = Allocation(
        asset_id=req.asset_id,
        user_id=req.user_id
    )
    
    asset = Asset.query.get(req.asset_id)
    asset.status = 'assigned'
    
    db.session.add(allocation)
    db.session.commit()
    
    return "Approved"
